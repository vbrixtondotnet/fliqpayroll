@{

    ViewData["Title"] = "Employees";

}



<div class="page-header d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">

    <div>

        <h1 class="h3 mb-1">Employees</h1>

        <p class="text-muted mb-0">Manage employee records with personal, employment, and government details.</p>

    </div>

    <button type="button" class="btn btn-primary" id="employee-add-btn">Add Employee</button>

</div>



<div class="card mb-3">

    <div class="card-body">

        <div class="row g-2 align-items-end">

            <div class="col-md-4">

                <label for="employee-filter-search" class="form-label mb-1">Search</label>

                <input type="text" id="employee-filter-search" class="form-control" placeholder="First or last name..." />

            </div>

            <div class="col-md-3">

                <label for="employee-filter-department" class="form-label mb-1">Department</label>

                <select id="employee-filter-department" class="form-select">

                    <option value="">All departments</option>

                </select>

            </div>

            <div class="col-md-2">

                <label for="employee-filter-status" class="form-label mb-1">Status</label>

                <select id="employee-filter-status" class="form-select">

                    <option value="">All</option>

                    <option value="true">Active</option>

                    <option value="false">Inactive</option>

                </select>

            </div>

            <div class="col-md-3">

                <button type="button" id="employee-filter-btn" class="btn btn-outline-primary me-2">Filter</button>

                <button type="button" id="employee-filter-reset-btn" class="btn btn-outline-secondary">Reset</button>

            </div>

        </div>

    </div>

</div>



<div id="employees-alert" class="alert alert-danger d-none" role="alert"></div>

<div id="employees-success" class="alert alert-success d-none" role="alert"></div>



<div class="card">

    <div class="card-body p-0">

        <div class="table-responsive">

            <table class="table table-hover mb-0 align-middle" id="employees-table">

                <thead class="table-light">

                    <tr>

                        <th>Code</th>

                        <th>Name</th>

                        <th>Department</th>

                        <th>Position</th>

                        <th>Basic Salary</th>

                        <th>Status</th>

                        <th style="width: 140px;"></th>

                    </tr>

                </thead>

                <tbody id="employees-body">

                    <tr>

                        <td colspan="7" class="text-center text-muted py-4">Loading employees...</td>

                    </tr>

                </tbody>

            </table>

        </div>

    </div>

</div>



<div class="modal fade" id="employee-modal" tabindex="-1" aria-labelledby="employee-modal-label" aria-hidden="true">

    <div class="modal-dialog modal-xl modal-dialog-scrollable">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title" id="employee-modal-label">Employee</h5>

                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>

            </div>

            <div class="modal-body">

                <form id="employee-form">

                    <input type="hidden" id="employee-id" />



                    <ul class="nav nav-tabs mb-3" role="tablist">

                        <li class="nav-item" role="presentation">

                            <button class="nav-link active" id="tab-personal" data-bs-toggle="tab" data-bs-target="#panel-personal" type="button" role="tab">Personal</button>

                        </li>

                        <li class="nav-item" role="presentation">

                            <button class="nav-link" id="tab-employment" data-bs-toggle="tab" data-bs-target="#panel-employment" type="button" role="tab">Employment</button>

                        </li>

                        <li class="nav-item" role="presentation">

                            <button class="nav-link" id="tab-government" data-bs-toggle="tab" data-bs-target="#panel-government" type="button" role="tab">Government</button>

                        </li>

                    </ul>



                    <div class="tab-content">

                        <div class="tab-pane fade show active" id="panel-personal" role="tabpanel">

                            <div class="row g-3">

                                <div class="col-md-3">

                                    <label for="employee-code" class="form-label">Employee Code</label>

                                    <input type="text" class="form-control" id="employee-code" required maxlength="20" />

                                </div>

                                <div class="col-md-3">

                                    <label for="employee-last-name" class="form-label">Last Name</label>

                                    <input type="text" class="form-control" id="employee-last-name" required maxlength="100" />

                                </div>

                                <div class="col-md-3">

                                    <label for="employee-first-name" class="form-label">First Name</label>

                                    <input type="text" class="form-control" id="employee-first-name" required maxlength="100" />

                                </div>

                                <div class="col-md-3">

                                    <label for="employee-middle-name" class="form-label">Middle Name</label>

                                    <input type="text" class="form-control" id="employee-middle-name" maxlength="100" />

                                </div>

                                <div class="col-md-3">

                                    <label for="employee-gender" class="form-label">Gender</label>

                                    <select class="form-select" id="employee-gender">

                                        <option value="">—</option>

                                        <option value="0">Male</option>

                                        <option value="1">Female</option>

                                        <option value="2">Other</option>

                                    </select>

                                </div>

                                <div class="col-md-3">

                                    <label for="employee-civil-status" class="form-label">Civil Status</label>

                                    <select class="form-select" id="employee-civil-status">

                                        <option value="">—</option>

                                        <option value="0">Single</option>

                                        <option value="1">Married</option>

                                        <option value="2">Widowed</option>

                                        <option value="3">Separated</option>

                                        <option value="4">Divorced</option>

                                    </select>

                                </div>

                                <div class="col-md-3">

                                    <label for="employee-dob" class="form-label">Date of Birth</label>

                                    <input type="date" class="form-control" id="employee-dob" />

                                </div>

                                <div class="col-md-3">

                                    <label for="employee-nationality" class="form-label">Nationality</label>

                                    <input type="text" class="form-control" id="employee-nationality" maxlength="100" />

                                </div>

                                <div class="col-md-3">

                                    <label for="employee-religion" class="form-label">Religion</label>

                                    <input type="text" class="form-control" id="employee-religion" maxlength="100" />

                                </div>

                                <div class="col-md-3">

                                    <label for="employee-mobile" class="form-label">Mobile</label>

                                    <input type="text" class="form-control" id="employee-mobile" maxlength="30" />

                                </div>

                                <div class="col-md-6">

                                    <label for="employee-email" class="form-label">Email</label>

                                    <input type="email" class="form-control" id="employee-email" maxlength="200" />

                                </div>

                                <div class="col-12">

                                    <label for="employee-address" class="form-label">Home Address</label>

                                    <textarea class="form-control" id="employee-address" rows="2" maxlength="500"></textarea>

                                </div>

                                <div class="col-md-4">

                                    <label for="employee-emergency-person" class="form-label">Emergency Contact</label>

                                    <input type="text" class="form-control" id="employee-emergency-person" maxlength="100" />

                                </div>

                                <div class="col-md-4">

                                    <label for="employee-emergency-number" class="form-label">Emergency Number</label>

                                    <input type="text" class="form-control" id="employee-emergency-number" maxlength="30" />

                                </div>

                                <div class="col-md-4">

                                    <label for="employee-emergency-relationship" class="form-label">Relationship</label>

                                    <input type="text" class="form-control" id="employee-emergency-relationship" maxlength="50" />

                                </div>

                            </div>

                        </div>



                        <div class="tab-pane fade" id="panel-employment" role="tabpanel">

                            <div class="row g-3">

                                <div class="col-md-3">

                                    <label for="employee-employment-status" class="form-label">Employment Status</label>

                                    <select class="form-select" id="employee-employment-status">

                                        <option value="0">Regular</option>

                                        <option value="1">Probationary</option>

                                        <option value="2">Contractual</option>

                                        <option value="3">Part Time</option>

                                        <option value="4">On Call</option>

                                    </select>

                                </div>

                                <div class="col-md-3">

                                    <label for="employee-department" class="form-label">Department</label>

                                    <input type="text" class="form-control" id="employee-department" maxlength="100" />

                                </div>

                                <div class="col-md-3">

                                    <label for="employee-position" class="form-label">Position</label>

                                    <input type="text" class="form-control" id="employee-position" maxlength="100" />

                                </div>

                                <div class="col-md-3">

                                    <label for="employee-supervisor" class="form-label">Supervisor</label>

                                    <input type="text" class="form-control" id="employee-supervisor" maxlength="100" />

                                </div>

                                <div class="col-md-3">

                                    <label for="employee-hire-date" class="form-label">Hire Date</label>

                                    <input type="date" class="form-control" id="employee-hire-date" required />

                                </div>

                                <div class="col-md-3">

                                    <label for="employee-regularized" class="form-label">Date Regularized</label>

                                    <input type="date" class="form-control" id="employee-regularized" />

                                </div>

                                <div class="col-md-3">

                                    <label for="employee-salary-type" class="form-label">Salary Type</label>

                                    <select class="form-select" id="employee-salary-type">

                                        <option value="0">Monthly</option>

                                        <option value="1">Daily</option>

                                        <option value="2">Fixed</option>

                                    </select>

                                </div>

                                <div class="col-md-3">

                                    <label for="employee-basic-salary" class="form-label">Basic Salary</label>

                                    <input type="number" class="form-control" id="employee-basic-salary" min="0" step="0.01" required />

                                </div>

                                <div class="col-md-3">

                                    <label for="employee-payroll-frequency" class="form-label">Payroll Frequency</label>

                                    <select class="form-select" id="employee-payroll-frequency">

                                        <option value="0">Bi-Monthly</option>

                                        <option value="1">Monthly</option>

                                    </select>

                                </div>

                                <div class="col-md-3">

                                    <label for="employee-bank-name" class="form-label">Bank Name</label>

                                    <input type="text" class="form-control" id="employee-bank-name" maxlength="100" />

                                </div>

                                <div class="col-md-3">

                                    <label for="employee-bank-account" class="form-label">Bank Account</label>

                                    <input type="text" class="form-control" id="employee-bank-account" maxlength="50" />

                                </div>

                                <div class="col-md-3 d-flex align-items-end">

                                    <div class="form-check">

                                        <input class="form-check-input" type="checkbox" id="employee-active" checked />

                                        <label class="form-check-label" for="employee-active">Active</label>

                                    </div>

                                </div>

                            </div>

                        </div>



                        <div class="tab-pane fade" id="panel-government" role="tabpanel">

                            <div class="row g-3">

                                <div class="col-md-4">

                                    <label for="employee-tin" class="form-label">TIN</label>

                                    <input type="text" class="form-control" id="employee-tin" maxlength="30" />

                                </div>

                                <div class="col-md-4">

                                    <label for="employee-sss-number" class="form-label">SSS Number</label>

                                    <input type="text" class="form-control" id="employee-sss-number" maxlength="30" />

                                </div>

                                <div class="col-md-4">

                                    <label for="employee-philhealth-number" class="form-label">PhilHealth Number</label>

                                    <input type="text" class="form-control" id="employee-philhealth-number" maxlength="30" />

                                </div>

                                <div class="col-md-4">

                                    <label for="employee-pagibig-number" class="form-label">Pag-IBIG Number</label>

                                    <input type="text" class="form-control" id="employee-pagibig-number" maxlength="30" />

                                </div>

                                <div class="col-md-4">

                                    <label for="employee-sss-er" class="form-label">SSS ER Share</label>

                                    <input type="number" class="form-control" id="employee-sss-er" min="0" step="0.01" />

                                </div>

                                <div class="col-md-4">

                                    <label for="employee-sss-ee" class="form-label">SSS EE Share</label>

                                    <input type="number" class="form-control" id="employee-sss-ee" min="0" step="0.01" />

                                </div>

                                <div class="col-md-4">

                                    <label for="employee-sss-loan" class="form-label">SSS Loan</label>

                                    <input type="number" class="form-control" id="employee-sss-loan" min="0" step="0.01" />

                                </div>

                                <div class="col-md-4">

                                    <label for="employee-philhealth-er" class="form-label">PhilHealth ER Share</label>

                                    <input type="number" class="form-control" id="employee-philhealth-er" min="0" step="0.01" />

                                </div>

                                <div class="col-md-4">

                                    <label for="employee-philhealth-ee" class="form-label">PhilHealth EE Share</label>

                                    <input type="number" class="form-control" id="employee-philhealth-ee" min="0" step="0.01" />

                                </div>

                                <div class="col-md-4">

                                    <label for="employee-pagibig-er" class="form-label">Pag-IBIG ER Share</label>

                                    <input type="number" class="form-control" id="employee-pagibig-er" min="0" step="0.01" />

                                </div>

                                <div class="col-md-4">

                                    <label for="employee-pagibig-ee" class="form-label">Pag-IBIG EE Share</label>

                                    <input type="number" class="form-control" id="employee-pagibig-ee" min="0" step="0.01" />

                                </div>

                                <div class="col-md-4">

                                    <label for="employee-pagibig-loan" class="form-label">Pag-IBIG Loan</label>

                                    <input type="number" class="form-control" id="employee-pagibig-loan" min="0" step="0.01" />

                                </div>

                            </div>

                        </div>

                    </div>

                </form>

            </div>

            <div class="modal-footer">

                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>

                <button type="button" class="btn btn-primary" id="employee-save-btn">Save</button>

            </div>

        </div>

    </div>

</div>



@section Scripts {

    <script src="~/js/employees.js" asp-append-version="true"></script>

}

