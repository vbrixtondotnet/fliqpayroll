@{
    ViewData["Title"] = "Holiday Calendar";
}

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Holiday Calendar</h1>
        <p class="text-muted mb-0">View and manage company holidays. Click a date to add or edit a holiday.</p>
    </div>
    <div class="d-flex align-items-center gap-2">
        <button type="button" id="holiday-prev-month" class="btn btn-outline-secondary btn-sm" aria-label="Previous month">&larr;</button>
        <h2 class="h5 mb-0" id="holiday-month-label"></h2>
        <button type="button" id="holiday-next-month" class="btn btn-outline-secondary btn-sm" aria-label="Next month">&rarr;</button>
        <button type="button" id="holiday-today-btn" class="btn btn-outline-primary btn-sm ms-2">Today</button>
    </div>
</div>

<div id="holiday-alert" class="alert alert-danger d-none" role="alert"></div>
<div id="holiday-success" class="alert alert-success d-none" role="alert"></div>

<div class="card">
    <div class="card-body p-0">
        <div class="holiday-calendar">
            <div class="holiday-calendar-weekdays">
                <div>Sun</div>
                <div>Mon</div>
                <div>Tue</div>
                <div>Wed</div>
                <div>Thu</div>
                <div>Fri</div>
                <div>Sat</div>
            </div>
            <div id="holiday-calendar-grid" class="holiday-calendar-grid"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="holiday-add-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Holiday</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-3" id="holiday-add-date-label"></p>
                <input type="hidden" id="holiday-add-date" />
                <div class="mb-3">
                    <label for="holiday-add-description" class="form-label">Description</label>
                    <input type="text" class="form-control" id="holiday-add-description" maxlength="200" placeholder="e.g. Independence Day" />
                </div>
                <div class="mb-3">
                    <label for="holiday-add-type" class="form-label">Holiday Type</label>
                    <select class="form-select" id="holiday-add-type">
                        <option value="0">Regular Holiday</option>
                        <option value="1">Special Holiday</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="holiday-save-btn">Save Holiday</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="holiday-detail-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Holiday Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-3" id="holiday-detail-date-label"></p>
                <input type="hidden" id="holiday-detail-id" />
                <div class="mb-3">
                    <label for="holiday-detail-description" class="form-label">Description</label>
                    <input type="text" class="form-control" id="holiday-detail-description" maxlength="200" />
                </div>
                <div class="mb-3">
                    <label for="holiday-detail-type" class="form-label">Holiday Type</label>
                    <select class="form-select" id="holiday-detail-type">
                        <option value="0">Regular Holiday</option>
                        <option value="1">Special Holiday</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-outline-danger" id="holiday-delete-btn">Delete</button>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" id="holiday-update-btn">Save Changes</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/holiday-calendar.js" asp-append-version="true"></script>
}
