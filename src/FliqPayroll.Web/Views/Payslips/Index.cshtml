@{

    ViewData["Title"] = "Payslips";

}



<div class="page-header mb-4">

    <h1 class="h3 mb-1">Payslips</h1>

    <p class="text-muted mb-0">View payroll summaries and download employee payslips.</p>

</div>



<div id="payslips-alert" class="alert alert-danger d-none" role="alert"></div>



<div class="card mb-3">

    <div class="card-body">

        <p class="fw-bold mb-3">Select Payroll Period</p>

        <div class="d-flex flex-wrap align-items-center gap-4">

            <div class="d-flex align-items-center gap-2">

                <label for="payslips-period-select" class="form-label mb-0 fw-semibold">Payroll Period</label>

                <select id="payslips-period-select" class="form-select" style="width: auto; min-width: 320px;">

                    <option value="">Select a saved payroll period</option>

                </select>

            </div>

            <div class="d-flex align-items-end gap-2 flex-wrap">

                <button type="button" id="payslips-generate-btn" class="btn btn-primary" disabled>Generate Payslips</button>

            </div>

        </div>

    </div>

</div>



<div class="row g-3 mb-4" id="payslips-summary-cards">

    <div class="col-md-4">

        <div class="summary-card card h-100">

            <div class="card-body">

                <div class="summary-label">Total Gross Pay</div>

                <div class="summary-value" id="payslip-total-gross">—</div>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="summary-card card h-100">

            <div class="card-body">

                <div class="summary-label">Total Deductions</div>

                <div class="summary-value" id="payslip-total-deductions">—</div>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="summary-card card h-100">

            <div class="card-body">

                <div class="summary-label">Total Net Pay</div>

                <div class="summary-value" id="payslip-total-net">—</div>

            </div>

        </div>

    </div>

</div>



<div id="payslips-table-toolbar" class="d-none d-flex justify-content-end mb-2">
    <a id="payslips-download-all-btn" class="btn btn-outline-primary" href="#" target="_blank" rel="noopener">Download All Payslips</a>
</div>

<div class="card">

    <div class="card-body p-0">

        <div class="table-responsive">

            <table class="table table-hover mb-0 align-middle" id="payslips-table">

                <thead class="table-light">

                    <tr>

                        <th>Code</th>

                        <th>Employee</th>

                        <th>Position</th>

                        <th>Gross</th>

                        <th>Deductions</th>

                        <th>Net Pay</th>

                        <th style="width: 100px;"></th>

                    </tr>

                </thead>

                <tbody id="payslips-body">

                    <tr>

                        <td colspan="7" class="text-center text-muted py-4">Select a saved payroll period and generate payslips.</td>

                    </tr>

                </tbody>

            </table>

        </div>

    </div>

</div>



@section Scripts {

    <script src="~/js/payslips.js" asp-append-version="true"></script>

}

