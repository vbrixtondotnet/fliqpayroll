@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header mb-4">
    <h1 class="h3 mb-1">Dashboard</h1>
    <p class="text-muted mb-0">Overview of employees, attendance, and payroll.</p>
</div>

<div id="dashboard-alert" class="alert alert-danger d-none" role="alert"></div>

<div class="row g-3" id="dashboard-cards">
    <div class="col-md-4 col-lg-2">
        <div class="card summary-card h-100">
            <div class="card-body">
                <div class="summary-label">Total Employees</div>
                <div class="summary-value" id="total-employees">—</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card summary-card h-100">
            <div class="card-body">
                <div class="summary-label">Active</div>
                <div class="summary-value" id="active-employees">—</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card summary-card h-100">
            <div class="card-body">
                <div class="summary-label">Present Today</div>
                <div class="summary-value text-success" id="present-today">—</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card summary-card h-100">
            <div class="card-body">
                <div class="summary-label">Absent Today</div>
                <div class="summary-value text-danger" id="absent-today">—</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card summary-card h-100">
            <div class="card-body">
                <div class="summary-label">Monthly Payroll</div>
                <div class="summary-value" id="monthly-payroll">—</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="card summary-card h-100">
            <div class="card-body">
                <div class="summary-label">Pending Payroll</div>
                <div class="summary-value text-warning" id="pending-payroll">—</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
}
